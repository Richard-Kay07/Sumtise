        {
          "name": "Get Vendor by ID",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Get first vendor ID from previous request",
                  "const vendorsResponse = pm.collectionVariables.get('vendorsResponse');",
                  "if (vendorsResponse) {",
                  "    const vendors = JSON.parse(vendorsResponse);",
                  "    if (vendors.vendors && vendors.vendors.length > 0) {",
                  "        pm.collectionVariables.set('testVendorId', vendors.vendors[0].id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{apiBase}}/vendors.getById?organizationId={{organizationId}}&id={{testVendorId}}",
              "host": ["{{apiBase}}"],
              "path": ["vendors.getById"],
              "query": [
                {
                  "key": "organizationId",
                  "value": "{{organizationId}}"
                },
                {
                  "key": "id",
                  "value": "{{testVendorId}}"
                }
              ]
            }
          }
        },
        {
          "name": "Create Vendor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Vendor created successfully', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('name');",
                  "    pm.collectionVariables.set('testVendorId', jsonData.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organizationId\": \"{{organizationId}}\",\n  \"name\": \"Test Vendor Ltd\",\n  \"alias\": \"TestVendor\",\n  \"email\": \"vendor@example.com\",\n  \"phone\": \"+44 20 1234 5678\",\n  \"address\": {\n    \"street\": \"123 Vendor St\",\n    \"city\": \"London\",\n    \"postcode\": \"SW1A 1AA\",\n    \"country\": \"United Kingdom\"\n  },\n  \"taxId\": \"GB123456789\",\n  \"paymentTerms\": 30,\n  \"currency\": \"GBP\",\n  \"taxScheme\": \"VAT_STANDARD\",\n  \"tags\": [\"test\", \"vendor\"]\n}"
            },
