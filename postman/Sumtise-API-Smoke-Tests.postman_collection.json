{
  "info": {
    "name": "Sumtise API Smoke Tests",
    "description": "API smoke tests for Sumtise accounting platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "sumtise-api-tests"
