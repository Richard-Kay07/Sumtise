// ─── Lease Accounting ─────────────────────────────────────────────────────────

model Lease {
  id             String @id @default(cuid())
  orgId          String
  leaseReference String
  description    String
  assetClass     String

  treatment                    String
  isShortTermExemption         Boolean  @default(false)
  isLowValueExemption          Boolean  @default(false)
  lowValueAssetCost            Decimal?

  commencementDate               DateTime
  originalEndDate                DateTime
  revisedEndDate                 DateTime?
  reviewDate                     DateTime?
  breakClauseDate                DateTime?
  breakClauseIsReasonablyCertain Boolean  @default(false)

  annualRentAmount         Decimal
  paymentFrequency         String
  paymentDayOfMonth        Int     @default(1)
  rentFreeMonths           Int     @default(0)
  incrementalBorrowingRate Decimal
  currency                 String  @default("GBP")

  rouAssetAccountId       String?
  leaseLiabilityAccountId String?
  depreciationAccountId   String?
  interestAccountId       String?
  rentExpenseAccountId    String?
  projectId               String?
  costCentreId            String?

  status             String    @default("ACTIVE")
  terminationDate    DateTime?
  terminationPenalty Decimal?

  landlordName    String?
  propertyAddress String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org                   Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  rouAssetAccount       ChartOfAccount? @relation("LeaseRouAssetAccount",    fields: [rouAssetAccountId],       references: [id], onDelete: SetNull)
  leaseLiabilityAccount ChartOfAccount? @relation("LeaseLiabilityAccount",   fields: [leaseLiabilityAccountId], references: [id], onDelete: SetNull)
  depreciationAccount   ChartOfAccount? @relation("LeaseDepreciationAccount", fields: [depreciationAccountId],   references: [id], onDelete: SetNull)
  interestAccount       ChartOfAccount? @relation("LeaseInterestAccount",     fields: [interestAccountId],       references: [id], onDelete: SetNull)
  rentExpenseAccount    ChartOfAccount? @relation("LeaseRentExpenseAccount",  fields: [rentExpenseAccountId],    references: [id], onDelete: SetNull)
