  OPENED
  CLICKED
  BOUNCED
  FAILED
  CANCELLED
}

// Payroll Module
model Employee {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?  // Link to User if employee has account
  employeeNumber String
  firstName      String
  lastName       String
  email          String?
  phone          String?
  address        Json?
  dateOfBirth    DateTime?
  startDate      DateTime
  endDate        DateTime?
  employmentType EmploymentType @default(FULL_TIME)
  status         EmployeeStatus @default(ACTIVE)
  salary         Decimal?  // Annual salary
  hourlyRate     Decimal?  // Hourly rate
  taxCode        String?   // UK tax code (e.g., "1257L")
  nationalInsuranceNumber String?
  pensionScheme  String?   // Pension scheme reference
  bankAccountNumber String?
  bankSortCode    String?
