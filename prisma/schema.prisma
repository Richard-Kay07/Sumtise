  depreciationAccount     ChartOfAccount? @relation("DepreciationAccount",        fields: [depreciationAccountId], references: [id], onDelete: SetNull)
  depreciationExpenseAccount ChartOfAccount? @relation("DepreciationExpenseAccount", fields: [expenseAccountId],   references: [id], onDelete: SetNull)
