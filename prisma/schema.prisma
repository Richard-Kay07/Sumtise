enum DepreciationMethod {
  STRAIGHT_LINE
  REDUCING_BALANCE
  UNITS_OF_PRODUCTION
  SUM_OF_YEARS_DIGITS
}

enum AssetStatus {
  ACTIVE
  DISPOSED
  FULLY_DEPRECIATED
  UNDER_MAINTENANCE
  WRITTEN_OFF
