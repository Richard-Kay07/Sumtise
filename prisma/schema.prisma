  SALE
  ADJUSTMENT
  TRANSFER
  WRITE_OFF
  RETURN_IN
  RETURN_OUT
}

// ─── Budgets ─────────────────────────────────────────────────────────────────

model Budget {
  id             String       @id @default(cuid())
  organizationId String
  projectId      String?
  name           String
  description    String?      @db.Text
  budgetType     BudgetType   @default(ANNUAL)
  periodStart    DateTime
  periodEnd      DateTime
  status         BudgetStatus @default(DRAFT)
  currency       String       @default("GBP")
  approvedAt     DateTime?
  approvedBy     String?
  notes          String?      @db.Text
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  lines        BudgetLine[]

  @@index([organizationId, status])
  @@index([organizationId, periodStart, periodEnd])
  @@map("budgets")
}

enum BudgetType {
  ANNUAL
  QUARTERLY
  MONTHLY
  PROJECT
  GRANT
}

enum BudgetStatus {
  DRAFT
  APPROVED
  ACTIVE
  CLOSED
  ARCHIVED
}

model BudgetLine {
  id             String   @id @default(cuid())
  organizationId String
  budgetId       String
  accountId      String
  description    String?
  periodStart    DateTime
  periodEnd      DateTime
  budgetedAmount Decimal
  actualAmount   Decimal  @default(0)
  variance       Decimal  @default(0)
  notes          String?  @db.Text
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  budget       Budget         @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  account      ChartOfAccount @relation(fields: [accountId], references: [id])

  @@index([organizationId, budgetId])
  @@index([organizationId, accountId])
  @@map("budget_lines")
}

// ─── Recurring Invoices ───────────────────────────────────────────────────────

model RecurringInvoice {
  id             String             @id @default(cuid())
  organizationId String
  customerId     String
  templateName   String
  frequency      RecurringFrequency
  dayOfMonth     Int?
  dayOfWeek      Int?
  startDate      DateTime
  endDate        DateTime?
  nextRunDate    DateTime
  lastRunDate    DateTime?
  status         RecurringStatus    @default(ACTIVE)
  subtotal       Decimal
  taxAmount      Decimal            @default(0)
  total          Decimal
  currency       String             @default("GBP")
  notes          String?            @db.Text
  paymentTerms   Int?               @default(30)
  autoSend       Boolean            @default(false)
  runCount       Int                @default(0)
  maxRuns        Int?
  metadata       Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization      Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer          Customer              @relation(fields: [customerId], references: [id])
  items             RecurringInvoiceItem[]
  generatedInvoices Invoice[]             @relation("RecurringInvoiceSource")

  @@index([organizationId, status])
  @@index([organizationId, nextRunDate])
  @@map("recurring_invoices")
}

enum RecurringFrequency {
  WEEKLY
  FORTNIGHTLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum RecurringStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

model RecurringInvoiceItem {
  id                 String           @id @default(cuid())
  recurringInvoiceId String
  description        String
  quantity           Decimal
  unitPrice          Decimal
  total              Decimal
  taxRate            Decimal          @default(0)

  recurringInvoice RecurringInvoice @relation(fields: [recurringInvoiceId], references: [id], onDelete: Cascade)

  @@map("recurring_invoice_items")
}

enum TaxSubmissionStatus {
  DRAFT
  SUBMITTED
  ACCEPTED
  REJECTED
  AMENDED
}

