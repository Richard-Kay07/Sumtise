# =============================================================================
# Sumtise — Environment Variables
# Copy this file to .env.local and fill in all required values.
# Do NOT commit .env.local to git.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://username:password@localhost:5432/sumtise"

# -----------------------------------------------------------------------------
# Clerk — Authentication (required)
# Get these from https://dashboard.clerk.com → your application → API Keys
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk redirect URLs (optional — these are the defaults)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/auth/signin"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/auth/signup"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# -----------------------------------------------------------------------------
# Google OAuth (optional — enable in Clerk dashboard → Social connections)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# AI — OpenAI (optional — required for AI features)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Email (required for transactional emails)
# EMAIL_PROVIDER options: sandbox | sendgrid | ses | mailgun | smtp
# Use "sandbox" in development — emails are logged to console, not sent.
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=sandbox
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=Sumtise
EMAIL_REPLY_TO=support@yourdomain.com
EMAIL_DOMAIN=yourdomain.com
EMAIL_SANDBOX_MODE=true

# SendGrid (if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# AWS SES (if EMAIL_PROVIDER=ses)
AWS_SES_REGION=eu-west-1
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY are shared with S3 below

# Mailgun (if EMAIL_PROVIDER=mailgun)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# SMTP / Gmail app-password (if EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASSWORD=

# -----------------------------------------------------------------------------
# File Storage
# FILE_STORAGE_PROVIDER options: local | s3 | gcs
# -----------------------------------------------------------------------------
FILE_STORAGE_PROVIDER=local
FILE_STORAGE_PATH=./uploads
FILE_MAX_SIZE=10485760
FILE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/csv,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
FILE_ENABLE_VIRUS_SCAN=false

# AWS S3 (if FILE_STORAGE_PROVIDER=s3)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Google Cloud Storage (if FILE_STORAGE_PROVIDER=gcs)
GCS_PROJECT_ID=
GCS_BUCKET=
GCS_KEY_FILENAME=

# -----------------------------------------------------------------------------
# Redis (optional — used for job queues and caching)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Internal API tokens
# -----------------------------------------------------------------------------
# Secret token for the invoice-reminder cron job endpoint
REMINDER_JOB_TOKEN=

# =============================================================================
# Legacy / unused — kept for reference only
# =============================================================================
# NEXTAUTH_URL and NEXTAUTH_SECRET were used before migrating to Clerk.
# They are no longer required but harmless if present.
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET=
