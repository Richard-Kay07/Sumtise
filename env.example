# File Storage
FILE_STORAGE_PROVIDER=local
FILE_STORAGE_PATH=./uploads
FILE_MAX_SIZE=10485760
FILE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/csv,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
FILE_ENABLE_VIRUS_SCAN=false

# AWS S3 (if FILE_STORAGE_PROVIDER=s3)
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Google Cloud Storage (if FILE_STORAGE_PROVIDER=gcs)
GCS_PROJECT_ID=
GCS_BUCKET=
GCS_KEY_FILENAME=

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/sumtise"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# OpenAI API
OPENAI_API_KEY="your-openai-api-key"

# Email Service
EMAIL_PROVIDER=sandbox
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_FROM_NAME=Sumtise
EMAIL_REPLY_TO=support@example.com
EMAIL_DOMAIN=example.com
EMAIL_SANDBOX_MODE=true

# SendGrid (if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# AWS SES (if EMAIL_PROVIDER=ses)
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Mailgun (if EMAIL_PROVIDER=mailgun)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# SMTP (if EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Payment Gateways
STRIPE_PUBLIC_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"

# Bank Integration
OPEN_BANKING_CLIENT_ID="your-open-banking-client-id"
OPEN_BANKING_CLIENT_SECRET="your-open-banking-client-secret"

# File Storage
UPLOADTHING_SECRET="your-uploadthing-secret"
UPLOADTHING_APP_ID="your-uploadthing-app-id"
